# Kisan Alert voice service — copy to .env and fill with ROTATED credentials.
# (The values in voice-agent-build-guide.md are burned; rotate before use.)

# ── LiveKit Cloud (livekit.com → project → Settings → Keys) ──
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Google AI Studio (aistudio.google.com) — Gemini Live ──
GOOGLE_API_KEY=
GEMINI_VOICE=Puck            # options: Puck, Charon, Kore, Fenrir, Aoede

# ── Vobiz SIP trunk (vobiz.ai) ──
VOBIZ_SIP_HOST=xxxx.sip.vobiz.ai
VOBIZ_PHONE_NUMBER=+91XXXXXXXXXX
VOBIZ_USERNAME=
VOBIZ_PASSWORD=

# ── LiveKit outbound trunk — printed by `python setup_trunks.py` ──
SIP_OUTBOUND_TRUNK_ID=

# ── App wiring ──
APP_URL=https://your-kisan-alert.run.app   # the Next.js web service URL
AGENT_NAME=kisan-voice
NOTIFY_SECRET=change-me-to-a-long-random-string   # must match the web app's NOTIFY_SECRET
